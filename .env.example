# Bot token: api.slack.com → your app → OAuth & Permissions → Bot User OAuth Token
# (available after installing the manifest-created app to the workspace)
SLACK_BOT_TOKEN=xoxb-...

# App-level token: api.slack.com → your app → Basic Information → App-Level Tokens
# Create one with the connections:write scope. App tokens cannot be declared in
# the manifest — this is the one manual step.
SLACK_APP_TOKEN=xapp-...

# Basic Information → App Credentials. Not required in Socket Mode; documented per spec.
SLACK_SIGNING_SECRET=

# Set to false to skip joining all public channels on startup; the bot then only
# listens in channels it is already a member of.
AUTO_JOIN_PUBLIC_CHANNELS=true
